# Supabase — project URL. Either name works; the server adapter checks both.
SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Publishable/anon key — safe to expose to the browser. Not required by the
# server data adapter today, but wire it up if you add client-side realtime.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Secret / service-role key — SERVER ONLY. Never put this in a NEXT_PUBLIC_*
# variable. With RLS disabled on every table, this grants full read/write.
SUPABASE_SECRET_KEY=sb_secret_xxx
# Legacy name also accepted:
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Feature flag — when "true" the frontend serves the static dummy fixture and
# skips all Supabase queries. Flip to "false" in production once the pipeline
# has populated country_activity with at least one date.
NEXT_PUBLIC_USE_DUMMY_DATA=true
