# SalientSignal pipeline environment variables.
#
# Copy this file to pipeline/.env and fill in the real values.
# .env is gitignored; .env.example is committed as documentation.
#
# The pipeline loads .env automatically via python-dotenv (see P2-C7 fix).
# If you prefer, export these in your shell instead — both work.

# -----------------------------------------------------------------------------
# Supabase (REQUIRED for live runs — dry-run mode doesn't need these)
# -----------------------------------------------------------------------------
# Get these from the Supabase dashboard → Project Settings → Data API.
#
# SUPABASE_URL is the project URL: https://<project-ref>.supabase.co
# SUPABASE_SECRET_KEY is the service_role key (starts with `sb_secret_...`
# in the new format, or `eyJhbGciOi...` in the legacy JWT format).
#
# NEVER commit the real values. NEVER use the anon key — it hits RLS and
# silently fails on writes.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SECRET_KEY=sb_secret_your_service_role_key_here

# -----------------------------------------------------------------------------
# Optional: override GDELT behavior for debugging
# -----------------------------------------------------------------------------
# GDELT_HTTP_TIMEOUT_SECONDS=30
# GDELT_MAX_RECORDS=250

# -----------------------------------------------------------------------------
# Optional: pipeline runtime tuning
# -----------------------------------------------------------------------------
# PIPELINE_TIME_BUDGET_SECONDS=3000   # 50 minutes (default)
# LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING | ERROR
