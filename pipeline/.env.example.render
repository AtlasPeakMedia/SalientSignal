# SalientSignal pipeline — Render environment variables manifest
#
# Phase E17 of the backfill plan. This file documents the environment
# variables the pipeline needs when running on Render's free-tier cron.
# DO NOT commit actual values here — paste them into the Render dashboard
# as environment variables on the "salientsignal-pipeline" cron service.
#
# Required:
# ---------

# Supabase project URL. Found at https://app.supabase.com/project/_/settings/api
# Example: https://bzmhnenqrilsrlxlujak.supabase.co
SUPABASE_URL=

# Supabase service role key. Found in the same settings panel as the URL.
# This is the secret key — NEVER commit it to git or paste it into code
# review comments. Treat it like a password.
SUPABASE_SECRET_KEY=

# Optional: Supabase fallback keys (for legacy local dev).
# Only one of SUPABASE_SECRET_KEY / SUPABASE_SERVICE_ROLE_KEY is needed.
# SUPABASE_SERVICE_ROLE_KEY=


# Optional (with sensible defaults):
# ----------------------------------

# Logging verbosity. INFO is safe for production; DEBUG is noisy but
# useful when diagnosing a specific failing run. Render's free tier
# retains ~100 MB of logs, so DEBUG fills up fast.
LOG_LEVEL=INFO

# Pipeline time budget. The pipeline will hard-abort with
# TimeBudgetExceeded if a single run goes beyond this many seconds.
# Default of 3000s (50 min) gives a 10-min buffer before the next
# hourly cron fires.
PIPELINE_TIME_BUDGET_SECONDS=3000

# Anthropic API key — OPTIONAL, unused in MVP.
# Required only for the paid tier AI debrief feature (post-launch). Not
# needed to keep the free tier running.
# ANTHROPIC_API_KEY=
